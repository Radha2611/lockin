{
  "expo": {
    "name": "lockin",
    "slug": "lockin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/lockin-logo.png.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/lockin-logo.png.png",
      "resizeMode": "contain",
      "backgroundColor": "#fafaf8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.radha2611.lockin",
      "adaptiveIcon": {
        "foregroundImage": "./assets/lockin-logo.png.png",
        "backgroundColor": "#fafaf8"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/lockin-logo.png.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "lockin uses photos to attach proof of your completed work.",
          "cameraPermission": "lockin uses the camera to snap proof of your completed work."
        }
      ],
      "expo-video",
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "08217f52-3f1a-41f6-96c3-16c8d9cd4da3"
      }
    }
  }
}
